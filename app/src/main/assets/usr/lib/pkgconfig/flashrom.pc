prefix=/data/data/com.diamon.curso/files/usr
includedir=${prefix}/include
libdir=${prefix}/lib

Name: flashrom
Description: library to interact with flashrom
Version: v1.7.0-rc2
Requires.private: libcrypto >= 3.0.0, libpci >= 2.2.0, libusb-1.0, libftdi1, libjaylink >= 0.3.0
Libs: -L${libdir} -lflashrom
Cflags: -I${includedir}

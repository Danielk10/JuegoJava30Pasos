<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F111A"
    android:padding="12dp">

    <!-- Indicador de Carga Inicial -->
    <LinearLayout
        android:id="@+id/layoutLoading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="visible"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/tvLoadingText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Preparando dependencias nativas..."
            android:textColor="#E0E0E0"
            android:textSize="16sp" />
    </LinearLayout>

    <!-- UI Principal -->
    <LinearLayout
        android:id="@+id/layoutMainUI"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@+id/adContainer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Estado USB: Desconectado"
            android:textColor="#4CAF50"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <Button
            android:id="@+id/btnConnect"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:padding="0dp"
            android:textSize="13sp"
            android:text="Detectar y Conectar Automáticamente"
            android:layout_marginBottom="4dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <Button
                android:id="@+id/btnProbe"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:enabled="false"
                android:padding="0dp"
                android:textSize="12sp"
                android:text="Identificar Chip" />

            <Space
                android:layout_width="4dp"
                android:layout_height="wrap_content"/>

            <Button
                android:id="@+id/btnVerify"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:enabled="false"
                android:padding="0dp"
                android:textSize="12sp"
                android:text="Verificar ROM" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <Button
                android:id="@+id/btnRead"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:enabled="false"
                android:padding="0dp"
                android:textSize="12sp"
                android:backgroundTint="#2E7D32"
                android:text="Leer Backup" />

            <Space
                android:layout_width="4dp"
                android:layout_height="wrap_content"/>

            <Button
                android:id="@+id/btnWrite"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:enabled="false"
                android:padding="0dp"
                android:textSize="12sp"
                android:backgroundTint="#C62828"
                android:text="Flashear ROM" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="4dp">

            <Button
                android:id="@+id/btnImport"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:padding="0dp"
                android:textSize="12sp"
                android:text="Cargar ROM" />

            <Space
                android:layout_width="4dp"
                android:layout_height="wrap_content"/>

            <Button
                android:id="@+id/btnExport"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:padding="0dp"
                android:textSize="12sp"
                android:text="Guardar ROM" />
        </LinearLayout>

        <EditText
            android:id="@+id/etCustomCommand"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:hint="Ej: -p ch341a_spi -L"
            android:inputType="text"
            android:maxLines="1"
            android:background="#1B1E2B"
            android:padding="4dp"
            android:textSize="13sp"
            android:textColorHint="#757575"
            android:textColor="#4DB6AC"
            android:layout_marginBottom="4dp" />

        <Button
            android:id="@+id/btnRunCustomCommand"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:padding="0dp"
            android:textSize="13sp"
            android:text="Ejecutar Instrucción"
            android:backgroundTint="#1565C0"
            android:layout_marginBottom="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="2dp">
            
            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Terminal Salida:"
                android:textColor="#B0BEC5"
                android:textSize="12sp"
                android:textStyle="bold"
                android:layout_gravity="center_vertical"/>
            
            <Button
                android:id="@+id/btnClearLogs"
                android:layout_width="wrap_content"
                android:layout_height="32dp"
                android:text="Limpiar"
                android:textSize="10sp"
                android:minHeight="0dp"
                android:padding="0dp"/>
        </LinearLayout>

        <!-- Terminal de Logs -->
        <ScrollView
            android:id="@+id/scrollLog"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#05070A"
            android:padding="6dp">

            <TextView
                android:id="@+id/tvLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:textIsSelectable="true"
                android:lineSpacingExtra="2dp"
                android:textColor="#00FF00"
                android:textSize="11sp"
                android:text="--- Log ---" />

        </ScrollView>

    </LinearLayout>

    <FrameLayout
        android:id="@+id/adContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>

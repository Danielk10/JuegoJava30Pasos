<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <!-- Indicador de Carga Inicial -->
    <LinearLayout
        android:id="@+id/layoutLoading"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="visible"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/tvLoadingText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Preparando dependencias nativas..."
            android:textSize="16sp" />
    </LinearLayout>

    <!-- UI Principal (Oculta hasta cargar dependencias) -->
    <LinearLayout
        android:id="@+id/layoutMainUI"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="USB Status: Desconectado"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnConnect"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Detectar y Conectar Automáticamente" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp">

            <Button
                android:id="@+id/btnProbe"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:enabled="false"
                android:text="Identificar Chip" />

            <Space
                android:layout_width="8dp"
                android:layout_height="wrap_content"/>

            <Button
                android:id="@+id/btnVerify"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:enabled="false"
                android:text="Verificar ROM" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/btnRead"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:enabled="false"
                android:backgroundTint="#4CAF50"
                app:autoSizeTextType="uniform"
                android:text="Leer Backup" />

            <Space
                android:layout_width="8dp"
                android:layout_height="wrap_content"/>

            <Button
                android:id="@+id/btnWrite"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                android:enabled="false"
                android:backgroundTint="#F44336"
                app:autoSizeTextType="uniform"
                android:text="Flashear ROM" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/btnImport"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                app:autoSizeTextType="uniform"
                android:text="Cargar\nROM" />

            <Space
                android:layout_width="8dp"
                android:layout_height="wrap_content"/>

            <Button
                android:id="@+id/btnExport"
                android:layout_width="0dp"
                android:layout_height="64dp"
                android:layout_weight="1"
                app:autoSizeTextType="uniform"
                android:text="Guardar ROM\nLeída" />
        </LinearLayout>

        <EditText
            android:id="@+id/etCustomCommand"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Comando flashrom manual (ej: --version o -p ch341a_spi -L)"
            android:inputType="text"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btnRunCustomCommand"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ejecutar comando manual"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Terminal Salida:"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <!-- Terminal de Logs -->
        <ScrollView
            android:id="@+id/scrollLog"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="#1E1E1E"
            android:padding="12dp">

            <TextView
                android:id="@+id/tvLog"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="monospace"
                android:textIsSelectable="true"
                android:lineSpacingExtra="3dp"
                android:longClickable="true"
                android:textColor="#00FF00"
                android:textSize="12sp"
                android:text="--- Log ---" />

        </ScrollView>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
